# =============================================================================
# KeeperHub Scheduler - Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# All three services (schedule-dispatcher, block-dispatcher, executor) share
# these core variables. Service-specific variables are noted below.
# =============================================================================

# -----------------------------------------------------------------------------
# KeeperHub API Connection (all services)
# -----------------------------------------------------------------------------
KEEPERHUB_API_URL=http://localhost:3000
KEEPERHUB_API_KEY=local-scheduler-key-for-dev

# -----------------------------------------------------------------------------
# AWS / SQS (all services)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/keeperhub-workflow-queue

# LocalStack only (local dev) - omit in production (uses IAM roles)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# -----------------------------------------------------------------------------
# Block Dispatcher only
# -----------------------------------------------------------------------------
# How often to refetch active block workflows from the API (ms)
RECONCILE_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# Health Check (per-service)
# -----------------------------------------------------------------------------
# Each service exposes /health on its own port.
# When running all services locally, they use different defaults to avoid conflicts:
#   schedule-dispatcher: 3060
#   block-dispatcher:    3050
#   executor:            3070
# In production (Helm), each pod sets HEALTH_PORT=3000 since they run in isolation.
# Uncomment to override:
# HEALTH_PORT=3000
