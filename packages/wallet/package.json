{
  "name": "@keeperhub/wallet",
  "version": "0.1.0",
  "description": "KeeperHub agentic wallet: auto-pay x402 and MPP 402 responses with a server-side Turnkey proxy.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "keeperhub-wallet": "./bin/keeperhub-wallet.js",
    "keeperhub-wallet-hook": "./bin/keeperhub-wallet-hook.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "2.48.1",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.9.2",
    "@types/node": "24.1.0",
    "vitest": "4.1.2",
    "msw": "2.13.4"
  }
}
