public-hoist-pattern[]=escalade
public-hoist-pattern[]=get-caller-file
public-hoist-pattern[]=graphile-config
public-hoist-pattern[]=graphile-worker
public-hoist-pattern[]=has-flag
public-hoist-pattern[]=import-fresh
public-hoist-pattern[]=interpret
public-hoist-pattern[]=is-arrayish
public-hoist-pattern[]=is-fullwidth-code-point
public-hoist-pattern[]=js-tokens
