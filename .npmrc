# Reject packages published less than 3 days ago to mitigate supply chain attacks
minimum-release-age=3d

# Force-hoist the full transitive dependency tree of @workflow/world-postgres.
# Next.js standalone output tracing cannot follow the dynamic
# require(process.env.WORKFLOW_TARGET_WORLD) in the workflow SDK.
# pnpm strict mode keeps transitive deps in .pnpm/ where the
# outputFileTracingIncludes globs in next.config.ts can't reach them.
#
# Regenerate with: tsx scripts/list-world-deps.ts
public-hoist-pattern[]=@babel/code-frame
public-hoist-pattern[]=@babel/helper-validator-identifier
public-hoist-pattern[]=@cbor-extract/cbor-extract-darwin-arm64
public-hoist-pattern[]=@cbor-extract/cbor-extract-darwin-x64
public-hoist-pattern[]=@cbor-extract/cbor-extract-linux-arm
public-hoist-pattern[]=@cbor-extract/cbor-extract-linux-arm64
public-hoist-pattern[]=@cbor-extract/cbor-extract-linux-x64
public-hoist-pattern[]=@cbor-extract/cbor-extract-win32-x64
public-hoist-pattern[]=@graphile/logger
public-hoist-pattern[]=@types/debug
public-hoist-pattern[]=@types/interpret
public-hoist-pattern[]=@types/ms
public-hoist-pattern[]=@types/pg
public-hoist-pattern[]=@types/semver
public-hoist-pattern[]=@vercel/oidc
public-hoist-pattern[]=@vercel/queue
public-hoist-pattern[]=@workflow/*
public-hoist-pattern[]=ansi-regex
public-hoist-pattern[]=ansi-styles
public-hoist-pattern[]=argparse
public-hoist-pattern[]=async-sema
public-hoist-pattern[]=balanced-match
public-hoist-pattern[]=brace-expansion
public-hoist-pattern[]=callsites
public-hoist-pattern[]=cbor-extract
public-hoist-pattern[]=cbor-x
public-hoist-pattern[]=chalk
public-hoist-pattern[]=cliui
public-hoist-pattern[]=color-convert
public-hoist-pattern[]=color-name
public-hoist-pattern[]=cosmiconfig
public-hoist-pattern[]=debug
public-hoist-pattern[]=detect-libc
public-hoist-pattern[]=emoji-regex
