# Exclude packages needed by sandbox/ workspace from minimum-release-age gate
minimum-release-age-exclude[]=vitest
minimum-release-age-exclude[]=@vitest/expect
minimum-release-age-exclude[]=@vitest/runner
minimum-release-age-exclude[]=@vitest/mocker
minimum-release-age-exclude[]=@vitest/pretty-format
