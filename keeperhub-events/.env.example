# =============================================================================
# KeeperHub Events - Docker Compose Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# KeeperHub API Configuration
# -----------------------------------------------------------------------------
# Use host.docker.internal to access services running on your host machine
# from within Docker containers (instead of localhost)
KEEPERHUB_API_URL=http://host.docker.internal:3000

# API key for authenticating with KeeperHub API
KEEPERHUB_API_KEY=local-events-key-for-dev

JWT_TOKEN_USERNAME=your-jwt-username
JWT_TOKEN_PASSWORD=your-jwt-password

# -----------------------------------------------------------------------------
# Worker Service Configuration
# -----------------------------------------------------------------------------
# Port for the event worker service (default: 3010)
WORKER_PORT=3010
TIMEOUT_BETWEEN_SYNC=30000

# -----------------------------------------------------------------------------
# Blockchain Configuration
# -----------------------------------------------------------------------------
# Etherscan API key for blockchain queries
ETHERSCAN_API_KEY=your-etherscan-api-key

NODE_ENV=development
